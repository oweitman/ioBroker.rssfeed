{
    "name": "iobroker.rssfeed",
    "version": "4.1.2",
    "description": "Adapter and vis widget for rss feeds",
    "author": {
        "name": "oweitman",
        "email": "oweitman@gmx.de"
    },
    "homepage": "https://github.com/oweitman/ioBroker.rssfeed",
    "license": "MIT",
    "keywords": [
        "ioBroker",
        "rss",
        "atom",
        "rdf",
        "feed"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/oweitman/ioBroker.rssfeed.git"
    },
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@iobroker/adapter-core": "^3.3.2",
        "axios": "^1.17.0",
        "chardet": "^2.1.1",
        "feedparser": "^2.6.0",
        "iconv-lite": "^0.7.2"
    },
    "devDependencies": {
        "@alcalzone/release-script": "^5.2.1",
        "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
        "@alcalzone/release-script-plugin-license": "^5.2.0",
        "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
        "@iobroker/adapter-dev": "^1.5.0",
        "@iobroker/eslint-config": "^2.3.4",
        "@iobroker/testing": "^5.2.2",
        "@tsconfig/node22": "^22.0.5",
        "@types/node": "^22.13.14",
        "@types/proxyquire": "^1.3.31",
        "proxyquire": "^2.1.3",
        "typescript": "~5.9.3"
    },
    "main": "main.js",
    "files": [
        "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|eslint.config.mjs|prettier.config.mjs).{json,json5}",
        "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
        "lib/",
        "widgets/**/!(tsconfig|tsconfig.*|eslint.config.mjs|prettier.config.mjs|en).json",
        "widgets/**/*.{html,css,png,svg,jpg,js}",
        "www/",
        "io-package.json",
        "LICENSE",
        "main.js"
    ],
    "scripts": {
        "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
        "test:package": "mocha test/package --exit",
        "test:integration": "mocha test/integration --exit",
        "test": "npm run test:integration && npm run test:package",
        "check": "tsc --noEmit -p tsconfig.check.json",
        "lint": "eslint -c eslint.config.mjs .",
        "npm": "npm i && cd widgets && npm i",
        "build": "cd widgets/rssfeed && npm run build && cd ../..",
        "repochecker": "npx @iobroker/repochecker https://github.com/oweitman/ioBroker.rssfeed --local --noinfo",
        "translate": "translate-adapter",
        "translate-widgets": "node ./bin/translate.js --source widgets/rssfeed/myi18n/en.json --format single",
        "release": "release-script --all"
    },
    "bugs": {
        "url": "https://github.com/oweitman/ioBroker.rssfeed/issues"
    },
    "readmeFilename": "README.md"
}
